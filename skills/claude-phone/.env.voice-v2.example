# OpenClaw-3CX Voice v2 Environment Configuration
# Copy this to .env.voice-v2 and fill in the values

# SIP/3CX Configuration
SIP_SERVER=pbx.right-api.com
SIP_USERNAME=voice-bot-v2
SIP_PASSWORD=your_secure_password_here

# Voice Gateway Configuration
WEBHOOK_URL=http://voice-processor:8080/incoming
LOG_LEVEL=info
CLAWDBOT_ID=luky-v2

# OpenAI API (Whisper STT)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ElevenLabs API (TTS)
ELEVENLABS_API_KEY=xi-your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Voice Processing Configuration
STT_MODEL=whisper-1
LLM_MODEL=claude-3-7-sonnet-20250219
MAX_CALL_DURATION=300
LANGUAGE=he

# Redis Configuration (optional, defaults shown)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring (optional)
ENABLE_MONITORING=true
PROMETHEUS_RETENTION=15d

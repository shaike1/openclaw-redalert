# ORef Alerts - OpenClaw Configuration
# העתק קובץ זה ל-.env ומלא את הערכים

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ORef API (לא לשנות בדרך כלל)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OREF_API_URL=http://localhost:9001/current
OREF_POLL_INTERVAL=5
OREF_COOLDOWN=60

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WhatsApp (חובה)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
WHATSAPP_GROUP_JID=120363XXXXXXXXX@g.us
WHATSAPP_OWNER=+972XXXXXXXXX

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Home Assistant (אופציונלי - לTTS קולי ואורות)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
HASS_SERVER=https://your-homeassistant.example.com
HASS_TOKEN=eyJhbGci...your_long_lived_token_here
HA_TTS_SPEAKER=media_player.home_assistant_voice_09a069
HA_ALERT_LIGHTS=light.living_room,light.kids_room

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 3CX חיוג טלפוני (אופציונלי)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OREF_PHONE_CALL=false
CX3_GATEWAY_URL=http://localhost:8090
CX3_EXTENSION=100
PHONE_ALERT_NUMBERS=+972XXXXXXXXX,+972YYYYYYYYY
